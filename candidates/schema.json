{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marguerite347/tari-diff-sim-multiplayer/candidates/schema.json",
  "title": "Tari network research candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "status",
    "origin",
    "authors",
    "hypothesis",
    "parameters",
    "threatModel",
    "benefits",
    "tradeoffs",
    "acceptanceCriteria",
    "reproduction",
    "integrity",
    "evidence",
    "decision"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,47}$" },
    "name": { "type": "string", "minLength": 3, "maxLength": 100 },
    "status": { "enum": ["draft", "exploratory", "approved", "randomized", "retired"] },
    "origin": { "enum": ["community", "builtin"] },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^@[A-Za-z0-9-]+$" }
    },
    "hypothesis": { "type": "string", "minLength": 20 },
    "parameters": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": ["string", "number", "boolean", "null"] }
    },
    "threatModel": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "benefits": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "tradeoffs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "acceptanceCriteria": {
      "type": "object",
      "required": ["success", "stability", "meanBt", "orphans", "deepestReorg", "worstGap", "diffSwing"],
      "additionalProperties": { "type": "string", "minLength": 3 }
    },
    "reproduction": {
      "type": "object",
      "required": ["instructions", "baseline", "seedsOrDataRange", "minimumSamplesPerCell"],
      "properties": {
        "instructions": { "type": "string", "minLength": 10 },
        "baseline": { "type": "string", "minLength": 3 },
        "seedsOrDataRange": { "type": "string", "minLength": 3 },
        "minimumSamplesPerCell": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "integrity": { "type": "string", "minLength": 20 },
    "evidence": { "type": "array", "items": { "type": "string", "format": "uri" } },
    "decision": {
      "type": "object",
      "required": ["summary", "reviewedBy"],
      "properties": {
        "summary": { "type": "string" },
        "reviewedBy": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
